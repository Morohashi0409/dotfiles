# Shell config (machine-local, may contain secrets)
.zshrc

# Secrets
.env
*.pem
id_rsa*
*.key

# Claude Code runtime state (contains oauthAccount/userID/projects history)
.claude.json
.claude.json.backup
.claude/

# External agent skills installed by Claude/Kiro plugin systems
# (canvas-design / polish etc. — re-installable from skills-lock.json)
.agents/
.kiro/

# OS
.DS_Store
DS_Store

# Python cache
__pycache__/
*.py[cod]

# Obsidian cache
config/obsidian/workspace.json
config/obsidian/workspace-mobile.json

# Obsidian plugin settings with local API credentials
config/obsidian/plugins/obsidian-textgenerator-plugin/data.json

# Obsidian community plugin bodies (re-downloaded by Obsidian itself from
# community-plugins.json). Keep only each plugin's data.json (user settings).
config/obsidian/plugins/**
!config/obsidian/plugins/
!config/obsidian/plugins/*/
!config/obsidian/plugins/*/data.json
